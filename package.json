{
  "name": "interview.ai",
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "cd apps/server && bun run build && cd ../client && bun run build",
    "dev": "bun run --workspaces dev",
    "start": "bun run --workspaces start",
    "dev:server": "cd apps/server && bun run dev",
    "dev:client": "cd apps/client && bun run dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "private": true,
  "dependencies": {}
}
